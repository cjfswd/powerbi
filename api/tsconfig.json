{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "skipLibCheck": true,
        "noEmit": true,
        "esModuleInterop": true,
        "allowJs": true,
        "resolveJsonModule": true
    },
    "include": [
        "."
    ],
    "exclude": [
        "scripts"
    ]
}